{
  "command_timeout": 5,
  "templates_folder": "Templates",
  "templates_pairs": [
    [
      "",
      ""
    ]
  ],
  "trigger_on_file_creation": true,
  "auto_jump_to_cursor": false,
  "enable_system_commands": false,
  "shell_path": "",
  "user_scripts_folder": "",
  "enable_folder_templates": true,
  "folder_templates": [
    {
      "folder": "Reviews/Daily",
      "template": "Templates/Daily.md"
    },
    {
      "folder": "Reviews/Weekly",
      "template": "Templates/Weekly Review {{YYYY}}-W{{ww}}.md"
    },
    {
      "folder": "Reviews/Monthly",
      "template": "Templates/Monthly Review{{YYYY-MM}}.md"
    },
    {
      "folder": "Reviews/Yearly",
      "template": "Templates/Yearly {{YYYY}}.md"
    }
  ],
  "enable_file_templates": false,
  "file_templates": [
    {
      "regex": ".*",
      "template": ""
    }
  ],
  "syntax_highlighting": true,
  "syntax_highlighting_mobile": false,
  "enabled_templates_hotkeys": [
    ""
  ],
  "startup_templates": [
    ""
  ],
  "intellisense_render": 1
}